Implementation detail:
Create a helper like:

selectReconAwareRowsForCurrentRun(
  rows: Seq[Row],
  maxFilesPerRun: Int,
  reconIdColumnName: String
): Seq[Row]

Logic:
1. Convert rows to indexed sequence to preserve original order:
   rows.zipWithIndex
2. Group by recon_id while preserving first occurrence order.
3. For each recon group in order:
   - reconFileCount = group.size
   - if selectedRows is empty and reconFileCount > maxFilesPerRun:
       select full recon group as oversized recon and stop
   - else if currentSelectedCount + reconFileCount <= maxFilesPerRun:
       add full recon group
   - else:
       stop; leave this recon and later recons for next trigger
4. Return selected rows only.

Pseudo-code:

def getReconId(row: Row, reconIdColumnName: String): String = {
  val value = row.getAs[Any](reconIdColumnName)
  if (value == null) "UNKNOWN" else value.toString
}

def selectReconAwareRowsForCurrentRun(
    rows: Seq[Row],
    maxFilesPerRun: Int,
    reconIdColumnName: String
): Seq[Row] = {

  val grouped = rows.zipWithIndex
    .groupBy { case (row, _) => getReconId(row, reconIdColumnName) }
    .toSeq
    .map { case (reconId, indexedRows) =>
      val sortedRows = indexedRows.sortBy(_._2).map(_._1)
      val firstIndex = indexedRows.map(_._2).min
      (reconId, sortedRows, firstIndex)
    }
    .sortBy { case (_, _, firstIndex) => firstIndex }

  val selected = scala.collection.mutable.ArrayBuffer[Row]()
  var selectedCount = 0
  var stop = false

  grouped.foreach { case (reconId, reconRows, _) =>
    if (!stop) {
      val reconFileCount = reconRows.size

      if (selected.isEmpty && reconFileCount > maxFilesPerRun) {
        // oversized recon, process full recon and stop
        selected ++= reconRows
        selectedCount += reconFileCount
        stop = true
      } else if (selectedCount + reconFileCount <= maxFilesPerRun) {
        selected ++= reconRows
        selectedCount += reconFileCount
      } else {
        // adding this recon would exceed max, leave it for next run
        stop = true
      }
    }
  }

  selected.toSeq
}

