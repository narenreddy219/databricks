1. DPP application-level summary

This tells whether the app itself had a surge.

WITH dpp_rows AS (
    SELECT
        REGEXP_SUBSTR(message, 'application_[0-9]+_[0-9]+') AS spark_application_id,
        TRIM(TO_CHAR(recon_id)) AS dpp_recon_id,
        REPLACE(TRIM(TO_CHAR(cob_date)), '-', '') AS cob_date_key,
        start_time,
        status,
        NVL(record_count, 0) AS record_count,
        message
    FROM fasttrac.om_recon_audit_log
    WHERE comp_nm IN ('DataPreProcessor', 'CorePreProcessor')
      AND start_time >= TRUNC(SYSDATE, 'IW')
      AND REGEXP_SUBSTR(message, 'application_[0-9]+_[0-9]+') IS NOT NULL
)

SELECT
    spark_application_id,

    COUNT(*) AS dpp_file_load_rows,
    COUNT(DISTINCT dpp_recon_id) AS distinct_recon_count,
    COUNT(DISTINCT cob_date_key) AS distinct_cob_count,

    SUM(record_count) AS total_dpp_record_count,
    MAX(record_count) AS max_single_recon_record_count,

    MIN(start_time) AS first_dpp_audit_time,
    MAX(start_time) AS last_dpp_audit_time,

    ROUND(
        (CAST(MAX(start_time) AS DATE) - CAST(MIN(start_time) AS DATE)) * 24 * 60,
        2
    ) AS dpp_audit_span_minutes

FROM dpp_rows
GROUP BY spark_application_id
ORDER BY
    dpp_file_load_rows DESC,
    total_dpp_record_count DESC;
What this proves

This directly answers:

Was this DPP app unusually large?
How many files/load events?
How many recons?
How many records?
How long did audit logging span?

For your finding, this should show something close to:

143 DPP rows
140 distinct recons

That is the app-level surge evidence.

2. Heavy contributors inside the same DPP app

Use the target recon only to derive the Spark application ID, then rank every recon inside that same app.

WITH target_app AS (
    SELECT DISTINCT
        REGEXP_SUBSTR(message, 'application_[0-9]+_[0-9]+') AS spark_application_id
    FROM fasttrac.om_recon_audit_log
    WHERE recon_id = '8200065'
      AND REPLACE(TO_CHAR(cob_date), '-', '') = '20260427'
      AND comp_nm IN ('DataPreProcessor', 'CorePreProcessor')
      AND REGEXP_SUBSTR(message, 'application_[0-9]+_[0-9]+') IS NOT NULL
),

app_rows AS (
    SELECT
        REGEXP_SUBSTR(a.message, 'application_[0-9]+_[0-9]+') AS spark_application_id,
        TRIM(TO_CHAR(a.recon_id)) AS dpp_recon_id,
        REPLACE(TRIM(TO_CHAR(a.cob_date)), '-', '') AS cob_date_key,
        a.start_time,
        a.status,
        NVL(a.record_count, 0) AS record_count,
        a.message
    FROM fasttrac.om_recon_audit_log a
    JOIN target_app t
        ON REGEXP_SUBSTR(a.message, 'application_[0-9]+_[0-9]+') = t.spark_application_id
    WHERE a.comp_nm IN ('DataPreProcessor', 'CorePreProcessor')
),

ranked AS (
    SELECT
        spark_application_id,
        dpp_recon_id,
        cob_date_key,

        COUNT(*) AS dpp_file_load_rows,
        SUM(record_count) AS total_record_count,
        MAX(record_count) AS max_record_count,

        MIN(start_time) AS first_dpp_time,
        MAX(start_time) AS last_dpp_time,

        RANK() OVER (
            ORDER BY SUM(record_count) DESC
        ) AS record_volume_rank

    FROM app_rows
    GROUP BY
        spark_application_id,
        dpp_recon_id,
        cob_date_key
)

SELECT
    spark_application_id,
    dpp_recon_id,
    cob_date_key,
    dpp_file_load_rows,
    total_record_count,
    max_record_count,
    record_volume_rank,
    first_dpp_time,
    last_dpp_time
FROM ranked
ORDER BY
    total_record_count DESC,
    dpp_file_load_rows DESC;
